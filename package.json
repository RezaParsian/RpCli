{
	"name": "@rezaparsian/rp-cli",
	"version": "0.2.0",
	"description": "AI-powered CLI — interactive chat, single prompts, and git commit message generation",
	"license": "MIT",
	"author": {
		"name": "RezaParsian",
		"url": "https://github.com/RezaParsian"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RezaParsian/RpCli.git"
	},
	"bugs": {
		"url": "https://github.com/RezaParsian/RpCli/issues"
	},
	"homepage": "https://github.com/RezaParsian/RpCli#readme",
	"keywords": [
		"cli",
		"ai",
		"commit",
		"git",
		"ink",
		"openai",
		"terminal"
	],
	"bin": {
		"rp-cli": "dist/cli.js"
	},
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"prepublishOnly": "pnpm run build",
		"test": "prettier --check . && xo && ava"
	},
	"dependencies": {
		"ink": "^7.0.1",
		"ink-big-text": "^2.0.0",
		"ink-gradient": "^4.0.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"marked": "^18.0.3",
		"meow": "^14.1.0",
		"openai": "^6.35.0",
		"react": "^19.2.5"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
